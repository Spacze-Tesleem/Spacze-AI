{
  "name": "Spacze AI",
  "build": {
    "context": ".",
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker": {}
  },
  "forwardPorts": [5173, 8080],
  "portsAttributes": {
    "5173": {
      "label": "Frontend (Vite)",
      "onAutoForward": "openPreview"
    },
    "8080": {
      "label": "API Server",
      "onAutoForward": "notify"
    }
  }
}
